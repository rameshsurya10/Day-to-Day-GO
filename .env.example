# ── Copy this file to .env.local for local dev. On your host, set these
#    as environment variables. Never put real secret values in this file.

# The single login password for the app. Pick something only you know.
# Put the REAL value in .env.local only — never here.
APP_PASSWORD=change-this-password

# A long random string used to sign the session cookie.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-string

# Cerebras API key for the AI coach — starts with "csk-".
# Get one at https://cloud.cerebras.ai
# Put the REAL value in .env.local only — never here.
CEREBRAS_API_KEY=

# Which Cerebras model the coach uses.
COACH_MODEL=gpt-oss-120b
